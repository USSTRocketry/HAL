{
  "$schema": "https://raw.githubusercontent.com/platformio/platformio-core/develop/platformio/assets/schema/library-json.json",
  "name": "HAL",
  "version": "0.1.0",
  "description": "Hardware Abstraction Layer for USST Rocketry avionics sensors, radios, and storage",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/USSTRocketry/HAL.git"
  },
  "authors": [
    {
      "name": "USST Rocketry"
    }
  ],
  "keywords": [
    "hal",
    "avionics",
    "rocketry"
  ],
  "build": {
    "srcDir": "implementations/arduino",
    "includeDir": ".",
    "flags": [
      "-std=gnu++20",
      "-D USST_PLATFORM_ARDUINO",
      "-D _TASK_HEADER_AND_CPP"
    ],
    "srcFilter": [
      "+<*.cpp>",
      "+<implementations/arduino/*.cpp>"
    ]
  },
  "dependencies": [
    {
      "name": "RadioHead",
      "version": "^1.120.0"
    },
    {
      "owner": "arkhipenko",
      "name": "TaskScheduler",
      "version": "^4.0.0"
    },
    {
      "owner": "adafruit",
      "name": "Adafruit BMP280 Library",
      "version": "^3.0.0"
    },
    {
      "owner": "adafruit",
      "name": "Adafruit GPS Library",
      "version": "^1.7.0"
    },
    {
      "owner": "adafruit",
      "name": "Adafruit LIS3MDL",
      "version": "^1.2.0"
    },
    {
      "owner": "adafruit",
      "name": "Adafruit LSM6DS",
      "version": "^4.7.0"
    },
    {
      "owner": "adafruit",
      "name": "Adafruit MCP9808 Library",
      "version": "^2.0.2"
    }
  ]
}
